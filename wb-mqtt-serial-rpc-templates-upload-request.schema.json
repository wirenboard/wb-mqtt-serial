  "type": "object",
  "properties": {
    "content": {
      "type": "string",
      "minLength": 1
    },
    "filename": {
      "type": "string",
      "minLength": 1
    },
    "lang": {
      "type": "string"
    },
    "force": {
      "type": "boolean"
    }
