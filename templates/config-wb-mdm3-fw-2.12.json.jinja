{% set INPUTS_NUMBER = 6 -%}
{% set OUTPUTS_NUMBER = 3 -%}
{% set ENCODERS_NUMBER = 3 -%}
{% set ENCODER_CHANGE_STEP_DEFAULT = 1 -%}
{% set ENCODER_CHANGE_STEP_MAX = 100 -%}
{% set PRESS_TYPES = ["single", "long", "double", "shortlong"] -%}

{
    "title": "WB-MDM3_template_title",
    "device_type": "WB-MDM3-since-fw-2.12",
    "group": "g-wb",
    "hw": [
        {
            "signature": "WBMD3",
            "fw": "2.12.0-rc3"
        }
    ],
    "device": {
        "name": "WB-MDM3",
        "id": "wb-mdm3",
        "max_read_registers": 0,
        "response_timeout_ms": 1,
        "frame_timeout_ms": 8,
        "enable_wb_continuous_read": true,

        "groups": [
            {% for ch_number in range(1, INPUTS_NUMBER + 1) -%}
            {
                "title": "Input {{ch_number}}",
                "id": "input_{{ch_number}}"
            },
            {% for press_type in PRESS_TYPES -%}
            {
                "title": "{{ press_type | title }} Press Action",
                "id": "input_{{ ch_number }}_{{ press_type | replace(' ', '_') }}_press_action",
                "group": "input_{{ ch_number }}"
            },
            {% endfor -%}
            {
                "title": "Action when Switch is On",
                "id": "input_{{ ch_number }}_switch_on_action",
                "group": "input_{{ ch_number }}"
            },
            {
                "title": "Action when Switch is Off",
                "id": "input_{{ ch_number }}_switch_off_action",
                "group": "input_{{ ch_number }}"
            },
            {
                "title": "Input Parameters",
                "id": "input_{{ ch_number }}_parameters",
                "group": "input_{{ ch_number }}"
            },
            {% endfor -%}
            {% for ch_number in range(0, OUTPUTS_NUMBER) -%}
            {
                "title": "Channel {{ch_number + 1}}",
                "id": "channel_{{ch_number + 1}}"
            },
            {% endfor -%}
            {% for ch_number in range(1, INPUTS_NUMBER + 1) -%}
            {
                "title": "Inputs {{ch_number}} Counters",
                "id": "input_{{ch_number}}_counters",
                "group": "input_{{ch_number}}",
                "ui_options": {
                    "wb": {
                        "disable_title": true
                    }
                }
            },
            {% endfor -%}

            {
                "title": "Encoders",
                "id": "g_encoders"
            },
            {% for encoder_number in range(1, ENCODERS_NUMBER + 1) -%}
            {
                "title": "Encoder {{encoder_number}}",
                "id": "gg_encoder_{{encoder_number}}",
                "group": "g_encoders"
            },
            {% endfor -%}
            {
                "title": "encoder_channels",
                "id": "gg_encoder_channels",
                "group": "g_encoders",
                "ui_options": {
                    "wb": {
                        "disable_title": true
                    }
                }
            },

            {
                "title": "Safety Mode",
                "id": "g_safety",
                "description": "g_safety_description"
            },
            {
                "title": "Power Up Behaviour",
                "id": "g_power_up_behaviour",
                "description": "g_power_up_behaviour_description"
            },
            {
                "title": "Safety Behaviour",
                "id": "gg_safety_behaviour",
                "group": "g_safety"
            },
            {% for ch_number in range(1, OUTPUTS_NUMBER + 1) -%}
            {
                "title": "Channel {{ ch_number }}",
                "id": "gg_safety_mode_ch_{{ ch_number }}",
                "group": "gg_safety_behaviour"
            },
            {
                "title": "Channel {{ ch_number }}",
                "id": "gg_power_up_behaviour_ch_{{ ch_number }}",
                "group": "g_power_up_behaviour"
            },
            {% endfor -%}
            {
                "title": "Inputs Control In Safety Mode",
                "id": "gg_safety_input_control",
                "description": "inputs_control_in_safety_mode_description",
                "group": "g_safety"
            },

            {
                "title": "General",
                "id": "general"
            },
            {
                "title": "Legacy Inputs Mode",
                "id": "gg_mode",
                "group": "general",
                "description": "inputs_mode_description"
            },
            {
                "title": "General Parameters",
                "id": "gg_general_parameters",
                "group": "general",
                "ui_options": {
                    "wb": {
                        "disable_title": true
                    }
                }
            },
            {
                "title": "General Channels",
                "id": "gg_general_channels",
                "group": "general",
                "ui_options": {
                    "wb": {
                        "disable_title": true
                    }
                }
            },
            {
                "title": "HW Info",
                "id": "hw_info"
            },
            {
                "title": "Debug",
                "id": "debug"
            }
        ],

        "parameters": [
            {% for ch_number in range(0, OUTPUTS_NUMBER) -%}
            {
                "id": "inputs{{ch_number * 2 + 1}}{{ch_number * 2 + 2}}_mode",
                "title": "Inputs {{ch_number * 2 + 1}}-{{ch_number * 2 + 2}}",
                "address": {{16 + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1, 2, 3],
                "default": 0,
                "enum_titles": [
                    "Control disabled",
                    "Control output {{ch_number + 1}} in 1-button mode",
                    "Control output {{ch_number + 1}} in 2-button mode",
                    "Custom mode"
                ],
                "group": "gg_mode",
                "order": {{ch_number}}
            },
            {% endfor -%}

            {% for ch_number in range(0, INPUTS_NUMBER) -%}
            {% for press_type in PRESS_TYPES -%}
            {% set action_bind = ("input {} {} press output".format(ch_number + 1, press_type))|replace(' ', '_')  -%}
            {% set selected_mode = ("inputs{}{}_mode".format(ch_number // 2 * 2 + 1, ch_number // 2 * 2 + 2)) -%}
            {% set cond_enc_num = (ch_number // 2) + 1 -%}
            {% set encoder_disabled_condition = "(encoder_" ~ cond_enc_num ~ "_mode==0)" if cond_enc_num <= ENCODERS_NUMBER else "(1==1)" -%}
            {
                "id": "{{action_bind}}_number",
                "title": "Output Number",
                "address": {{768 + (loop.index0 * 16) + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1, 2, 3, 100],
                "enum_titles": [
                    "No Action",
                    "Output 1",
                    "Output 2",
                    "Output 3",
                    "All Outputs"
                ],
                "default": 0,
                "group": "input_{{ ch_number + 1 }}_{{ press_type | replace(' ', '_') }}_press_action",
                "order": 1,
                "condition": "input_{{ch_number + 1}}_mode!=1&&{{encoder_disabled_condition}}"
            },
            {
                "id": "{{action_bind}}_action_single",
                "title": "Action",
                "address": {{832 + (loop.index0 * 16) + ch_number}},
                "reg_type": "holding",
                {% if press_type in ["long", "shortlong"] %}"enum": [0, 1, 2, 3, 4, 5],{% else %}"enum": [0, 1, 2, 3, 4],{% endif %}
                "enum_titles": [
                    "Turn Off",
                    "Turn On",
                    "Toggle",
                    "Decrease level",
                    "Increase level"{% if press_type in ["long", "shortlong"] %},
                    "Increase/Decrease level"{% endif %}
                ],
                "default": 0,
                "group": "input_{{ ch_number + 1 }}_{{ press_type | replace(' ', '_') }}_press_action",
                "order": 2,
                "condition": "({{action_bind}}_number>=1)&&({{action_bind}}_number<=3)&&{{encoder_disabled_condition}}"
            },
            {
                "id": "{{action_bind}}_action_all",
                "title": "Action",
                "address": {{832 + (loop.index0 * 16) + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1, 3, 4],
                "enum_titles": [
                    "Turn Off",
                    "Turn On",
                    "Decrease level",
                    "Increase level"
                ],
                "default": 0,
                "group": "input_{{ ch_number + 1 }}_{{ press_type | replace(' ', '_') }}_press_action",
                "order": 2,
                "condition": "{{action_bind}}_number==100&&{{encoder_disabled_condition}}"
            },
            {% endfor -%}
            {% for sw_act in ["off", "on"] -%}
            {% set cond_enc_num = (ch_number // 2) + 1 -%}
            {% set encoder_disabled_condition = "(encoder_" ~ cond_enc_num ~ "_mode==0)" if cond_enc_num <= ENCODERS_NUMBER else "(1==1)" -%}
            {
                "id": "input_{{ch_number + 1}}_switch_{{sw_act}}_channel",
                "title": "Output Number",
                "address": {{704 + (loop.index0 * 16) + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1, 2, 3, 100],
                "enum_titles": [
                    "No Action",
                    "Output 1",
                    "Output 2",
                    "Output 3",
                    "All Outputs"
                ],
                "default": 0,
                "group": "input_{{ ch_number + 1}}_switch_{{sw_act}}_action",
                "condition": "input_{{ch_number + 1}}_mode==1&&{{encoder_disabled_condition}}",
                "order": 1
            },
            {
                "id": "input_{{ch_number + 1}}_switch_{{sw_act}}_action_single",
                "title": "Action",
                "address": {{736 + (loop.index0 * 16) + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1, 2],
                "enum_titles": [
                    "Turn Off",
                    "Turn On",
                    "Toggle"
                ],
                "default": {{ 0 if sw_act == "off" else 1}},
                "group": "input_{{ ch_number + 1}}_switch_{{sw_act}}_action",
                "condition": "input_{{ch_number + 1}}_switch_{{sw_act}}_channel>=1&&input_{{ch_number + 1}}_switch_{{sw_act}}_channel<=3&&{{encoder_disabled_condition}}",
                "order": 2
            },
            {
                "id": "input_{{ch_number + 1}}_switch_{{sw_act}}_action_all",
                "title": "Action",
                "address": {{736 + (loop.index0 * 16) + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1],
                "enum_titles": [
                    "Turn Off",
                    "Turn On"
                ],
                "default": {{ 0 if sw_act == "off" else 1}},
                "group": "input_{{ ch_number + 1}}_switch_{{sw_act}}_action",
                "condition": "input_{{ch_number + 1}}_switch_{{sw_act}}_channel==100&&{{encoder_disabled_condition}}",
                "order": 2
            },
            {% endfor -%}{% endfor -%}
            {
                "id": "safety_timer_s",
                "title": "Safety Poll Timeout (s)",
                "group": "g_safety",
                "description": "poll_timeout_description",
                "address": 8,
                "order": 2,
                "reg_type": "holding",
                "min": 1,
                "max": 65534,
                "default": 10
            },
            {% for ch_number in range(1, OUTPUTS_NUMBER + 1) -%}
            {
                "id": "safety_mode_ch_{{ch_number}}_action",
                "title": "Action",
                "reg_type": "holding",
                "address": {{648 + ch_number - 1}},
                "type": "enum",
                "enum": [0, 1, 2, 3],
                "enum_titles": [
                    "No Action",
                    "Turn Off",
                    "Turn On",
                    "Set Brightness"
                ],
                "group": "gg_safety_mode_ch_{{ ch_number }}"
            },
            {
                "id": "safety_mode_ch_{{ch_number}}_level",
                "title": "Brightness (%)",
                "description": "level_after_actions_description",
                "reg_type": "holding",
                "address": {{656 + ch_number - 1}},
                "min": 0,
                "max": 100,
                "default": 50,
                "required": true,
                "condition": "safety_mode_ch_{{ch_number}}_action==3",
                "group": "gg_safety_mode_ch_{{ ch_number }}"
            },
            {
                "id": "power_up_behaviour_ch_{{ch_number}}_action",
                "title": "Action",
                "reg_type": "holding",
                "address": {{664 + ch_number - 1}},
                "type": "enum",
                "enum": [0, 1, 2, 3],
                "enum_titles": [
                    "Turn Off",
                    "Set Previous State",
                    "Turn On",
                    "Set Brightness"
                ],
                "group": "gg_power_up_behaviour_ch_{{ ch_number }}"
            },
            {
                "id": "power_up_behaviour_ch_{{ch_number}}_level",
                "title": "Brightness (%)",
                "description": "level_after_actions_description",
                "reg_type": "holding",
                "address": {{672 + ch_number - 1}},
                "min": 0,
                "max": 100,
                "default": 50,
                "required": true,
                "condition": "power_up_behaviour_ch_{{ch_number}}_action==3",
                "group": "gg_power_up_behaviour_ch_{{ ch_number }}"
            },
            {% endfor -%}
            {% for in_number in range(1, INPUTS_NUMBER + 1) -%}
            {
                "id": "in_{{in_number}}_safety_input_control",
                "title": "Input {{in_number}}",
                "group": "gg_safety_input_control",
                "address": {{640 + in_number - 1}},
                "reg_type": "holding",
                "default": 0,
                "enum": [0, 1, 2],
                "enum_titles": [
                    "Don't change",
                    "Disable in safety mode",
                    "Enable only in safety mode"
                ]
            },
            {% endfor -%}

            {% for ch_number in range(0, INPUTS_NUMBER) -%}
            {% set selected_mode = ("inputs{}{}_mode".format(ch_number // 2 * 2 + 1, ch_number // 2 * 2 + 2)) -%}
            {% set cond_enc_num = (ch_number // 2) + 1 -%}
            {% set encoder_disabled_condition = "(encoder_" ~ cond_enc_num ~ "_mode==0)" if cond_enc_num <= ENCODERS_NUMBER else "(1==1)" -%}
            {
                "id": "input_{{ch_number + 1}}_mode",
                "title": "Input Mode",
                "description": "input_mode_description",
                "address": {{416 + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1],
                "enum_titles": [
                    "Button",
                    "Switch"
                ],
                "required": true,
                "default": 0,
                "condition": "(isDefined({{selected_mode}})==0||{{selected_mode}}==3)&&{{encoder_disabled_condition}}",
                "group": "input_{{ch_number + 1}}"
            },
            {
                "id": "input_{{ch_number + 1}}_hold_time",
                "title": "Long Press Time (ms)",
                "description": "input_hold_time_description",
                "address": {{1100 + ch_number}},
                "reg_type": "holding",
                "default": 1000,
                "min": 500,
                "max": 5000,
                "group": "input_{{ch_number + 1}}_parameters",
                "condition": "input_{{ch_number + 1}}_mode!=1&&{{encoder_disabled_condition}}",
                "order": 1
            },
            {
                "id": "input_{{ch_number + 1}}_double_time",
                "title": "Second Press Waiting Time (ms)",
                "description": "input_double_time_description",
                "address": {{1140 + ch_number}},
                "reg_type": "holding",
                "default": 300,
                "min": 0,
                "max": 2000,
                "group": "input_{{ch_number + 1}}_parameters",
                "condition": "input_{{ch_number + 1}}_mode!=1&&{{encoder_disabled_condition}}",
                "order": 2
            },
            {
                "id": "input_{{ch_number + 1}}_debounce_time",
                "title": "Debounce Time (ms)",
                "description": "input_debounce_time_description",
                "address": {{1160 + ch_number}},
                "reg_type": "holding",
                "default": 50,
                "min": 0,
                "max": 200,
                "group": "input_{{ch_number + 1}}_parameters",
                "order": 3
            },
            {% endfor -%}

            {% for encoder_number in range(1, ENCODERS_NUMBER + 1) -%}
            {
                "id": "encoder_{{encoder_number}}_mode",
                "title": "Encoder Connection Type",
                "description": "encoder_{{encoder_number}}_mode_description",
                "address": {{376 + encoder_number - 1}},
                "reg_type": "holding",
                "enum": [0, 1],
                "enum_titles": [
                    "Not used",
                    "AB type"
                ],
                "default": 0,
                "group": "gg_encoder_{{encoder_number}}",
                "order": 1
            },
            {
                "id": "encoder_{{encoder_number}}_pulses_per_step",
                "title": "Pulses per Step",
                "address": {{384 + encoder_number - 1}},
                "reg_type": "holding",
                "min": 1,
                "max": 100,
                "default": 4,
                "group": "gg_encoder_{{encoder_number}}",
                "condition": "encoder_{{encoder_number}}_mode==1",
                "order": 2
            },
            {
                "id": "encoder_{{encoder_number}}_controlled_channel",
                "title": "Controlled Channel",
                "address": {{388 + encoder_number - 1}},
                "reg_type": "holding",
                "enum": [0, {% for ch_number in range(1, OUTPUTS_NUMBER + 1) %}{{ch_number}}{% if not loop.last %}, {% endif %}{% endfor %}],
                "enum_titles": [
                    "No Control",
                    {% for ch_number in range(1, OUTPUTS_NUMBER + 1) -%}
                    "Channel {{ch_number}}"{% if not loop.last %},{% endif %}
                    {% endfor -%}
                ],
                "default": 0,
                "group": "gg_encoder_{{encoder_number}}",
                "condition": "encoder_{{encoder_number}}_mode==1",
                "order": 3
            },
            {
                "id": "encoder_{{encoder_number}}_change_step",
                "title": "Level Change Step (%)",
                "address": {{392 + encoder_number - 1}},
                "reg_type": "holding",
                "min": 1,
                "max": {{ENCODER_CHANGE_STEP_MAX}},
                "default": {{ENCODER_CHANGE_STEP_DEFAULT}},
                "group": "gg_encoder_{{encoder_number}}",
                "condition": "encoder_{{encoder_number}}_mode==1&&encoder_{{encoder_number}}_controlled_channel!=0",
                "order": 4
            },
            {
                "id": "encoder_{{encoder_number}}_min_br_behavior",
                "title": "Behavior When Level is Reduced Below the Minimum Value",
                "address": {{396 + encoder_number - 1}},
                "reg_type": "holding",
                "enum": [0, 1],
                "enum_titles": [
                    "Turn Off the Channel",
                    "Keep Minimum Level"
                ],
                "default": 0,
                "group": "gg_encoder_{{encoder_number}}",
                "condition": "encoder_{{encoder_number}}_mode==1&&encoder_{{encoder_number}}_controlled_channel!=0",
                "order": 5
            },
            {% endfor -%}
            {% for ch_number in range(0, OUTPUTS_NUMBER) -%}
            {
                "id": "channel{{ ch_number + 1}}_dimming_curve",
                "title": "Channel {{ ch_number + 1}} Dimming Curve",
                "address": {{50 + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1, 2],
                "default": 0,
                "enum_titles": [
                    "LED lamp or incandescent lamp (logarithmic)",
                    "resistive load (linear)",
                    "switching mode (on/off)"
                ],
                "group": "channel_{{ ch_number + 1}}",
                "order": 1
            },
            {
                "id": "channel{{ ch_number + 1}}_dimming_type",
                "title": "Channel {{ ch_number + 1}} Dimming Type",
                "address": {{60 + ch_number}},
                "reg_type": "holding",
                "enum": [0, 1],
                "default": 0,
                "enum_titles": [
                    "leading edge (motors, fans, incandescent lamps)",
                    "trailing edge (LED lamps)"
                ],
                "group": "channel_{{ ch_number + 1 }}",
                "order": 2
            },
            {
                "id": "channel{{ ch_number + 1 }}_min_value",
                "title": "Channel {{ ch_number + 1 }} Min Value (us)",
                "description": "channel_min_value_description",
                "address": {{70 + ch_number}},
                "reg_type": "holding",
                "min": 0,
                "max": 9999,
                "default": 1000,
                "group": "channel_{{ ch_number + 1 }}",
                "order": 3
            },
            {
                "id": "channel{{ ch_number + 1 }}_max_value",
                "title": "Channel {{ ch_number + 1 }} Max Value (us)",
                "description": "channel_max_value_description",
                "address": {{80 + ch_number}},
                "reg_type": "holding",
                "min": 0,
                "max": 9999,
                "default": 9999,
                "group": "channel_{{ ch_number + 1 }}",
                "order": 4
            },
            {
                "id": "channel{{ ch_number + 1 }}_increase_rate",
                "title": "Channel {{ ch_number + 1 }} Increase Rate (ms/%)",
                "description": "increase_rate_description",
                "address": {{140 + ch_number}},
                "reg_type": "holding",
                "min": 0,
                "max": 100,
                "default": 10,
                "group": "channel_{{ ch_number + 1 }}",
                "order": 5
            },
            {
                "id": "channel{{ ch_number + 1 }}_decrease_rate",
                "title": "Channel {{ ch_number + 1 }} Decrease Rate (ms/%)",
                "description": "decrease_rate_description",
                "address": {{150 + ch_number}},
                "reg_type": "holding",
                "min": 0,
                "max": 100,
                "default": 10,
                "group": "channel_{{ ch_number + 1 }}",
                "order": 6
            },
            {
                "id": "action{{ch_number + 1}}_repeat_time",
                "title": "Action Repeat Time (ms)",
                "description": "action_repeat_time_description",
                "group": "channel_{{ch_number + 1}}",
                "address": {{896 + ch_number}},
                "reg_type": "holding",
                "default": 20,
                "min": 5,
                "max": 500,
                "order": 7
            },
            {% endfor -%}

            {
                "id": "baud_rate",
                "title": "Baud rate",
                "description": "baud_rate_description",
                "address": 110,
                "reg_type": "holding",
                "enum": [96, 192, 384, 576, 1152],
                "default": 96,
                "enum_titles": [
                    "9600",
                    "19200",
                    "38400",
                    "57600",
                    "115200"
                ],
                "group": "gg_general_parameters"
            }
        ],

        "channels": [
            {% for ch_number in range(0, INPUTS_NUMBER) -%}
            {% set cond_enc_num = (ch_number // 2) + 1 -%}
            {% set encoder_disabled_condition = "(encoder_" ~ cond_enc_num ~ "_mode==0)" if cond_enc_num <= ENCODERS_NUMBER else "(1==1)" -%}
            {
                "name": "Input {{ch_number + 1}}",
                "reg_type": "discrete",
                "address": {{ch_number}},
                "type": "switch",
                "group": "input_{{ch_number + 1}}_counters",
                "condition": "{{encoder_disabled_condition}}",
                "sporadic": true
            },
            {
                "name": "Input {{ch_number + 1}} counter",
                "reg_type": "input",
                "address": {{32 + ch_number}},
                "type": "value",
                "group": "input_{{ch_number + 1}}_counters",
                "condition": "{{encoder_disabled_condition}}",
                "sporadic": true
            },
            {
                "name": "Input {{ch_number + 1}} Single Press Counter",
                "reg_type": "press_counter",
                "address": {{464 + ch_number}},
                "type": "value",
                "group": "input_{{ch_number + 1}}_counters",
                "condition": "input_{{ch_number + 1}}_mode!=1&&{{encoder_disabled_condition}}",
                "sporadic": true
            },
            {
                "name": "Input {{ch_number + 1}} Long Press Counter",
                "reg_type": "press_counter",
                "address": {{480 + ch_number}},
                "type": "value",
                "group": "input_{{ch_number + 1}}_counters",
                "condition": "input_{{ch_number + 1}}_mode!=1&&{{encoder_disabled_condition}}",
                "sporadic": true
            },
            {
                "name": "Input {{ch_number + 1}} Double Press Counter",
                "reg_type": "press_counter",
                "address": {{496 + ch_number}},
                "type": "value",
                "enabled": false,
                "group": "input_{{ch_number + 1}}_counters",
                "condition": "input_{{ch_number + 1}}_mode!=1&&{{encoder_disabled_condition}}",
                "sporadic": true
            },
            {
                "name": "Input {{ch_number + 1}} Shortlong Press Counter",
                "reg_type": "press_counter",
                "address": {{512 + ch_number}},
                "type": "value",
                "enabled": false,
                "group": "input_{{ch_number + 1}}_counters",
                "condition": "input_{{ch_number + 1}}_mode!=1&&{{encoder_disabled_condition}}",
                "sporadic": true
            },
            {% endfor -%}

            {% for encoder_number in range(1, ENCODERS_NUMBER + 1) -%}
            {
                "name": "Encoder {{encoder_number}} Position",
                "enabled": false,
                "reg_type": "holding",
                "address": {{368 + (encoder_number - 1) * 2}},
                "type": "value",
                "format": "u32",
