                "Off Pulse": "Отключить на время",
                "On/Off Cycle": "Цикл On/Off",
                "On Time (s)": "Включено (с)",
                "Off Time (s)": "Отключено (с)",
                "Timeout (s)": "Таймаут (с)",
                "Time (s)": "Время (с)",

                "Curtains Control": "Управление приводом",
